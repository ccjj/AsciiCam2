<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent" >

    <SurfaceView
        android:id="@+id/cameraView"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />

    <FrameLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" >

        <com.dozingcatsoftware.asciicam.OverlayView
            android:id="@+id/overlayView"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:gravity="top|center" />

        <!-- Portrait layout: compact horizontal button bar at bottom for TikTok-like experience -->
        <LinearLayout
            android:id="@+id/verticalButtonBar"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="2dp"
            android:paddingTop="2dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:background="#60000000"
            android:visibility="visible" >

            <com.dozingcatsoftware.util.ShutterButton
                android:id="@+id/shutterButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp"
                android:background="#00000000"
                android:clickable="true"
                android:scaleType="fitCenter"
                android:src="@drawable/btn_camera_shutter_new" />

            <ImageButton
                android:id="@+id/cycleColorButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp"
                android:background="#00000000"
                android:scaleType="fitCenter"
                android:onClick="onClick_cycleColorMode"
                android:src="@drawable/btn_color_full_color_new" />

            <ImageButton
                android:id="@+id/settingsButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp"
                android:background="#00000000"
                android:scaleType="fitCenter"
                android:onClick="onClick_gotoPreferences"
                android:contentDescription="@string/settingsButtonDescription"
                android:tooltipText="@string/settingsButtonDescription"
                android:src="@drawable/ic_settings_new" />

            <ImageButton
                android:id="@+id/galleryButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp"
                android:background="#00000000"
                android:scaleType="fitCenter"
                android:onClick="onClick_gotoGallery"
                android:src="@drawable/ic_photo_library_new" />

            <ImageButton
                android:id="@+id/convertPictureButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp"
                android:background="#00000000"
                android:scaleType="fitCenter"
                android:onClick="onClick_convertPicture"
                android:src="@drawable/convert_new" />

            <ImageButton
                android:id="@+id/switchCameraButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp"
                android:background="#00000000"
                android:scaleType="fitCenter"
                android:onClick="onClick_switchCamera"
                android:src="@drawable/ic_camera_rear_new" />

            <ImageButton
                android:id="@+id/helpButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp"
                android:background="#00000000"
                android:scaleType="fitCenter"
                android:onClick="onClick_gotoAbout"
                android:src="@drawable/ic_help_new" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>