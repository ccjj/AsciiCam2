<?xml version="1.0" encoding="utf-8"?>
<manifest package="com.dozingcatsoftware.asciicam" xmlns:android="http://schemas.android.com/apk/res/android">
  <uses-permission android:name="android.permission.CAMERA"/>
  <!-- Add INTERNET only if you stream/upload -->
  <!-- <uses-permission android:name="android.permission.INTERNET"/> -->
  <!-- Remove legacy storage perms if present:
       READ_EXTERNAL_STORAGE / WRITE_EXTERNAL_STORAGE -->

  <application
    android:allowBackup="true"
    android:label="@string/app_name"
    android:icon="@drawable/ic_launcher_new"
    android:theme="@style/Theme.ACTheme"
    android:supportsRtl="true"
    android:hardwareAccelerated="true"
    android:largeHeap="true">
    
    <activity android:name=".MainActivity" 
      android:exported="true"
      android:screenOrientation="unspecified"
      android:theme="@style/Theme.ACTheme"
      android:configChanges="keyboard|keyboardHidden|orientation|screenSize">
      <intent-filter>
        <action android:name="android.intent.action.MAIN"/>
        <category android:name="android.intent.category.LAUNCHER"/>
      </intent-filter>
    </activity>
    
    <activity android:name=".LibraryActivity" android:exported="false"/>
    <activity android:name=".ViewImageActivity" android:screenOrientation="unspecified" android:exported="false"/>
    <activity android:name=".AboutActivity" android:exported="false"/>
    <activity android:name=".AsciiCamPreferences" android:exported="false"/>

    <provider
      android:name="androidx.core.content.FileProvider"
      android:authorities="${applicationId}.fileprovider"
      android:exported="false"
      android:grantUriPermissions="true">
      <meta-data
        android:name="android.support.FILE_PROVIDER_PATHS"
        android:resource="@xml/provider_paths"/>
    </provider>
  </application>
</manifest>